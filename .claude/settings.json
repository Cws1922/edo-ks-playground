{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix src/ 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(./node_modules/.bin/eslint:*)",
      "Bash(./node_modules/.bin/tsc:*)",
      "Bash(node --version)",
      "Bash(fnm:*)",
      "Bash(nvm:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)"
    ]
  }
}
